اكتب("probe_arabic_text")

بيت := "ريم على القاع بين البان و العلم"
اكتب("text", بيت)
اكتب("len", حجم(بيت))

ا := 0
طالما ا < حجم(بيت):
    اكتب("char", ا, بيت[ا])
    اذا بيت[ا] = " ":
        اكتب("space", ا)
    غيره:
        اكتب("non_space", ا)
    ا := ا + 1

كلمات := اقسم(بيت، " ")
اكتب("split", كلمات)
اكتب("split_len", حجم(كلمات))

اذا حجم(كلمات) > 0:
    اكتب("first_word", كلمات[0])
غيره:
    اكتب("no_words")

اكتب("slice_0_3", مقطع(بيت، 0، 3))
اكتب("substr_0_3", substr(بيت، 0، 3))
اكتب("rejoin", join(كلمات، "|"))
