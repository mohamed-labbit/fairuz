اكتب("probe_word_tally")

كلمات := ["نور"، "ليل"، "نور"، "شمس"، "ليل"، "نور"، "قمر"، "شمس"، "نور"]
فريدة := قائمة()
عدادات := قائمة()

ا := 0
طالما ا < حجم(كلمات):
    كلمة := كلمات[ا]
    وجد := خطا
    ج := 0
    طالما ج < حجم(فريدة):
        اذا فريدة[ج] = كلمة:
            عدادات[ج] := عدادات[ج] + 1
            وجد := صحيح
            ج := حجم(فريدة)
        غيره:
            ج := ج + 1
    اذا وجد:
        ا := ا
    غيره:
        اضف(فريدة، كلمة)
        اضف(عدادات، 1)
    ا := ا + 1

اكتب("unique", فريدة)
اكتب("counts", عدادات)

تقرير := {}
ا := 0
طالما ا < حجم(فريدة):
    تقرير[فريدة[ا]] := عدادات[ا]
    ا := ا + 1

اكتب("report", تقرير)
