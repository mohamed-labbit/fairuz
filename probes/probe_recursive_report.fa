اكتب("probe_recursive_report")

دالة مجموع_حتى(ن):
    اذا ن = 0:
        ارجع 0
    غيره:
        ارجع ن + مجموع_حتى(ن - 1)

دالة فيب(ن):
    اذا ن < 2:
        ارجع ن
    غيره:
        ارجع فيب(ن - 1) + فيب(ن - 2)

دالة ابن_زوجي(ن):
    اذا ن = 0:
        ارجع صحيح
    غيره:
        ارجع ابنى_فردي(ن - 1)

دالة ابنى_فردي(ن):
    اذا ن = 0:
        ارجع خطا
    غيره:
        ارجع ابن_زوجي(ن - 1)

نتائج := قائمة()
ا := 0
طالما ا < 8:
    اضف(نتائج، مجموع_حتى(ا))
    اضف(نتائج، فيب(ا))
    اضف(نتائج، ابن_زوجي(ا))
    ا := ا + 1

اكتب("results", نتائج)
اكتب("joined", join(نتائج، ","))
