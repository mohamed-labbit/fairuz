اكتب("probe_matrix_walk")

مصفوفة := [[1، 2، 3]، [4، 5، 6]، [7، 8، 9]]

مجموع := 0
صف := 0
طالما صف < حجم(مصفوفة):
    عمود := 0
    طالما عمود < حجم(مصفوفة[صف]):
        قيمة := مصفوفة[صف][عمود]
        مجموع := مجموع + قيمة
        اكتب("cell", صف, عمود, قيمة, مجموع)
        عمود := عمود + 1
    صف := صف + 1

اكتب("sum", مجموع)

قطر := قائمة()
ا := 0
طالما ا < حجم(مصفوفة):
    اضف(قطر، مصفوفة[ا][ا])
    ا := ا + 1

اكتب("diag", قطر)
اكتب("diag_join", join(قطر، "-"))
