اكتب("probe_bool_and_none")

دالة راقب_علم(اسم، علم):
    اكتب("flag", اسم, علم)
    اذا علم:
        اكتب("truthy", اسم)
    غيره:
        اكتب("falsy", اسم)

    اذا علم = صحيح:
        اكتب("eq_true", اسم)
    غيره:
        اكتب("not_eq_true", اسم)

    اذا علم = خطا:
        اكتب("eq_false", اسم)
    غيره:
        اكتب("not_eq_false", اسم)

قاموس := {"جاهز": صحيح, "خامد": خطا}
راقب_علم("literal_true"، صحيح)
راقب_علم("literal_false"، خطا)
راقب_علم("dict_true"، قاموس["جاهز"])
راقب_علم("dict_false"، قاموس["خامد"])

مفقود := قاموس["غير_موجود"]
اكتب("missing", مفقود)

اذا مفقود:
    اكتب("missing_truthy")
غيره:
    اكتب("missing_falsy")

اذا مفقود = عدم:
    اكتب("missing_eq_none")
غيره:
    اكتب("missing_not_eq_none")

اذا عدم = عدم:
    اكتب("none_eq_none_literal")
غيره:
    اكتب("none_not_eq_none_literal")
