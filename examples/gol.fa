صفر := حجم("")
واحد := حجم("ا")
اثنان := واحد + واحد
ثلاثة := اثنان + واحد
أربعة := ثلاثة + واحد
خمسة := أربعة + واحد
ستة := خمسة + واحد
سبعة := ستة + واحد
ثمانية := سبعة + واحد
تسعة := ثمانية + واحد
عشرة := تسعة + واحد
أحدعشر := عشرة + واحد
اثناعشر := عشرة + اثنان
عشرون := عشرة + عشرة

صفوف := اثناعشر
أعمدة := عشرون
آخرصف := صفوف - واحد
آخرعمود := أعمدة - واحد
خطوات := اثناعشر
حجمالشبكة := صفوف * أعمدة
رموز := ["م"، "ح"]
قواعد := [صفر، صفر، صفر، واحد، صفر، صفر، صفر، صفر، صفر، صفر، صفر، واحد، واحد، صفر، صفر، صفر، صفر، صفر]

شبكة := قائمة()
مؤشر := صفر
طالما مؤشر < حجمالشبكة:
    اضف(شبكة، صفر)
    مؤشر := مؤشر + واحد

شبكة[أعمدة + اثنان] := واحد
شبكة[اثنان * أعمدة + ثلاثة] := واحد
شبكة[ثلاثة * أعمدة + واحد] := واحد
شبكة[ثلاثة * أعمدة + اثنان] := واحد
شبكة[ثلاثة * أعمدة + ثلاثة] := واحد

شبكة[خمسة * أعمدة + ثلاثة] := واحد
شبكة[ستة * أعمدة + أربعة] := واحد
شبكة[سبعة * أعمدة + اثنان] := واحد
شبكة[سبعة * أعمدة + ثلاثة] := واحد
شبكة[سبعة * أعمدة + أربعة] := واحد

شبكة[ستة * أعمدة + عشرة] := واحد
شبكة[ستة * أعمدة + أحدعشر] := واحد
شبكة[ستة * أعمدة + اثناعشر] := واحد

صف := صفر
عمود := صفر
سطر := ""
موضع := صفر
التالي := قائمة()
فوق := صفر
وسط := صفر
تحت := صفر
الجيران := صفر
الخلية := صفر

جيل := صفر
طالما جيل < خطوات:
    اكتب("جيل")
    صف := صفر
    طالما صف < صفوف:
        سطر := ""
        عمود := صفر
        طالما عمود < أعمدة:
            موضع := صف * أعمدة + عمود
            سطر := سطر + رموز[شبكة[موضع]]
            عمود := عمود + واحد
        اكتب(سطر)
        صف := صف + واحد
    اكتب("")

    التالي := قائمة()
    مؤشر := صفر
    طالما مؤشر < حجمالشبكة:
        اضف(التالي، صفر)
        مؤشر := مؤشر + واحد

    صف := واحد
    طالما صف < آخرصف:
        عمود := واحد
        طالما عمود < آخرعمود:
            فوق := (صف - واحد) * أعمدة
            وسط := صف * أعمدة
            تحت := (صف + واحد) * أعمدة
            موضع := وسط + عمود
            الجيران := شبكة[فوق + عمود - واحد] + شبكة[فوق + عمود] + شبكة[فوق + عمود + واحد] + شبكة[وسط + عمود - واحد] + شبكة[وسط + عمود + واحد] + شبكة[تحت + عمود - واحد] + شبكة[تحت + عمود] + شبكة[تحت + عمود + واحد]
            الخلية := شبكة[موضع]
            التالي[موضع] := قواعد[الخلية * تسعة + الجيران]

            عمود := عمود + واحد
        صف := صف + واحد

    شبكة := التالي
    جيل := جيل + واحد
