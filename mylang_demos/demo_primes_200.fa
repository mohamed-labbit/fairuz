دالة منخل(حد):
    مركب := قائمة()
    عداد := 0
    طالما عداد < حد + 1:
        اضف(مركب، صحيح)
        عداد := عداد + 1
    مركب[0] := خطا
    مركب[1] := خطا
    ي := 2
    طالما (ي * ي) <= حد:
        اذا مركب[ي]:
            مضاعف := ي * ي
            طالما مضاعف <= حد:
                مركب[مضاعف] := خطا
                مضاعف := مضاعف + ي
        ي := ي + 1
    اولية := قائمة()
    ك := 2
    طالما ك <= حد:
        اذا مركب[ك]:
            اضف(اولية، ك)
        ك := ك + 1
    ارجع اولية

اولية := منخل(200)
اكتب(len(اولية))
اكتب(اولية[0])
اكتب(اولية[10])
اكتب(اولية[len(اولية) - 1])
