نص := trim("  alpha,beta,gamma,delta  ")
اكتب(نص)

اجزاء := split(نص, ",")
اكتب(len(اجزاء))
اكتب(اجزاء[0])
اكتب(اجزاء[3])

مقطع := substr(نص, 6, 10)
اكتب(مقطع)
اكتب(contains(نص, "gamma"))

مربوط := join(اجزاء, "|")
اكتب(مربوط)

ل := قائمة()
اضف(ل، len(نص))
اضف(ل، len(مربوط))
اضف(ل، len(اجزاء))
اكتب(ل)
