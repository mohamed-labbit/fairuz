some.cpp#!/usr/bin/env python3
"""
Script to generate test input files for parser tests.
Run this in your test cases directory.
"""

from pathlib import Path

# Test cases with their content
test_cases = {
    # Complex Expression Tests
    "complex_expression.txt": "2 + 3 * 4",
    "nested_parens.txt": "((2 + 3) * 4)",
    "chained_comparison.txt": "ا < ب < ت",
    "logical_expression.txt": "ا و ب او ت",
    "unary_chain.txt": "--ب",
    "complex_function_call.txt": "علم(ا + ب, ت * ث)",
    
    # Error Handling Tests
    "invalid_syntax.txt": "+ +",
    "missing_operand.txt": "ا +",
    "unmatched_paren.txt": "(ا + ب",
    "extra_paren.txt": "ا + ب)",
    "unexpected_eof.txt": "ا + ب +",
    "invalid_operator_seq.txt": "ا ++ ب",
    
    # Edge Cases
    "empty_input.txt": "",
    "whitespace_only.txt": "   \n\n   \n",
    "single_identifier.txt": "ا",
    "long_identifier.txt": "ا" * 1000,
    "unicode_identifiers.txt": "ا + ب",
    "empty_list.txt": "[]",
    "empty_tuple.txt": "()",
    "list_trailing_comma.txt": "[1, 2, 3,]",
    "nested_lists.txt": "[[1, 2], [3, 4]]",
    "assignment.txt": "ا = 42",
    "chained_assignment.txt": "ا = ب = 5",
    
    # Performance Tests (Optional)
    "large_file.txt": "\n".join([f"x{i} = {i} + {i+1}" for i in range(5000)]),
    "deeply_nested.txt": "(" * 100 + "ا" + ")" * 100,
}

def create_test_files(output_dir: Path):
    """Create all test input files in the specified directory."""
    output_dir.mkdir(parents=True, exist_ok=True)
    
    for filename, content in test_cases.items():
        filepath = output_dir / filename
        with open(filepath, 'w', encoding='utf-8') as f:
            f.write(content)
        print(f"Created: {filepath}")
    
    print(f"\n✓ Successfully created {len(test_cases)} test files in {output_dir}")

if __name__ == "__main__":
    # Adjust this path to your test cases directory
    test_dir = Path("test/parser_test_cases")
    create_test_files(test_dir)build/
