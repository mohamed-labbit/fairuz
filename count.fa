بيت := "ريم على القاع بين البان و العلم أحل سفك دمي بالأشهر الحرم"
ا := 0
كلمات := قائمة()
كلمة := ""
طالما ا < حجم(بيت):
    حرف := بيت[ا]
    اذا حرف != " ":
        كلمة := كلمة + حرف
        ا := ا + 1
    غيره:
        اضف(كلمات، كلمة)
        كلمة := ""
        ا := ا + 1
اذا كلمة != "":
    اضف(كلمات، كلمة)
ا := حجم(كلمات) - 1
طالما ا > -1:
    اكتب(كلمات[ا])
    ا := ا - 1